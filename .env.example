# InsForge (Open_House) — sin slash final en la URL
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_URL=https://your-appkey.us-east.insforge.app
INSFORGE_API_KEY=

# Obtener anon key: npx @insforge/cli secrets get ANON_KEY
# API key: .insforge/project.json → api_key

# Legacy Supabase (opcional durante transición)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Email, Kommo, SMS (sin cambios)
# EMAIL_USER=
# EMAIL_PASS=
# KOMMO_*=
# SMS_GATEWAY_*=
